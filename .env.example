# ---------------------------------------------------------------------------
# Prepartido3RFEF — variables de entorno
# Copia este archivo a ".env" y ajusta los valores.
# ---------------------------------------------------------------------------

# Base de datos local SQLite (no se sube a ningún sitio).
DATABASE_URL="file:./dev.db"

# Contraseña de acceso local a la aplicación (login básico privado).
# Cámbiala por la que quieras.
APP_PASSWORD="arbitro"

# Secreto para firmar la cookie de sesión local.
AUTH_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# ---------------------------------------------------------------------------
# Proveedores de datos (OPCIONAL).
# La app funciona perfectamente SIN ninguna API configurada.
# Valores posibles de ACTIVE_DATA_PROVIDER: manual | csv | besoccer | apifootball
# ---------------------------------------------------------------------------
ACTIVE_DATA_PROVIDER=manual

# Claves de API externas (déjalas vacías si no las tienes).
BESOCCER_API_KEY=
API_FOOTBALL_KEY=
